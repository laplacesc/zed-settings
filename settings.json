{
  "terminal": {
    "font_family": "Sarasa Term SC Nerd",
  },
  "ui_font_family": "Sarasa UI SC",
  "auto_install_extensions": {
    "html": true,
    "catppuccin": true,
    "catppuccin-icons": true,
    "markdownlint": true,
    "markdown-oxide": true,
  },
  "agent_servers": {
    "claude-acp": {
      "default_config_options": {
        "mode": "auto",
      },
      "type": "registry",
    },
  },
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "tree_view": true,
    "dock": "left",
  },
  "buffer_font_family": "LXGW Bright Code NF GB",
  "icon_theme": "Catppuccin Latte",
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "theme": "Catppuccin Latte",
}
